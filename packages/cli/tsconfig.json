{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2023"
    ],
    "types": [
      "node",
      "vitest/globals"
    ],
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strict": false,
    "strictPropertyInitialization": true,
    "strictFunctionTypes": false,
    "useUnknownInCatchVariables": false
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "./package.json"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "references": [
    {
      "path": "../core"
    }
  ]
}